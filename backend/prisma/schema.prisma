generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  //url      = env("DATABASE_URL")
}

// 1. THÊM ROLE ACCOUNTER
enum Role {
  USER
  AUTHOR
  ADMIN
  ACCOUNTER 
}

// 2. THÊM TRẠNG THÁI TRUYỆN/CHƯƠNG
enum Status {
  PUBLISHED
  HIDDEN
  BANNED
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String?   
  name           String
  avatar         String?
  role           Role      @default(USER)
  points         Int       @default(0)
  totalDeposited Int       @default(0) 
  createdAt      DateTime  @default(now())

  comics           Comic[]
  comments         Comment[]
  transactions     Transaction[]
  unlockedChapters UnlockedChapter[]
  favorites        Favorite[]
  readingHistories ReadingHistory[]
  notifications    Notification[]
  createdTags      Tag[] 
  
  ratings          Rating[] // 👈 THÊM ĐÚNG 1 DÒNG NÀY VÀO ĐÂY
}

model Comic {
  id            String   @id @default(uuid())
  authorId      String
  title         String
  description   String
  coverUrl      String
  status        Status   @default(PUBLISHED) // Ẩn/Hiện truyện
  views         Int      @default(0)
  averageRating Float    @default(0)
  createdAt     DateTime @default(now())

  author           User              @relation(fields: [authorId], references: [id])
  chapters         Chapter[]
  tags             Tag[]
  comments         Comment[]
  favorites        Favorite[]
  ratings          Rating[]
  readingHistories ReadingHistory[]
}

model Tag {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  authorId    String?  // Nếu null là do hệ thống tạo, nếu có id là do tác giả tạo
  isApproved  Boolean  @default(true) // Tag do tác giả tạo cần Admin duyệt
  
  comics      Comic[]
  creator     User?    @relation(fields: [authorId], references: [id])
}

model Chapter {
  id          String   @id @default(uuid())
  comicId     String
  title       String
  orderNumber Int
  price       Int      @default(0)
  status      Status   @default(PUBLISHED) // Ẩn/Hiện chương
  createdAt   DateTime @default(now())

  comic            Comic             @relation(fields: [comicId], references: [id], onDelete: Cascade)
  images           ChapterImage[]
  unlockedBy       UnlockedChapter[]
  readingHistories ReadingHistory[]
  comments         Comment[] // BÌNH LUẬN TRONG TỪNG CHƯƠNG
}

model ChapterImage {
  id         String  @id @default(uuid())
  chapterId  String
  url        String
  pageNumber Int

  chapter    Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

// BÌNH LUẬN: ĐÃ NÂNG CẤP ĐỂ CÓ REPLY VÀ BÌNH LUẬN THEO CHƯƠNG
model Comment {
  id        String   @id @default(uuid())
  userId    String
  comicId   String?  // Có thể null nếu bình luận vào chương
  chapterId String?  // Có thể null nếu bình luận vào truyện
  parentId  String?  // NẾU CÓ: Đây là một câu trả lời (Reply) cho comment khác
  content   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comic     Comic?   @relation(fields: [comicId], references: [id], onDelete: Cascade)
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  receiverId  String?  // Dùng khi chuyển điểm giữa 2 user
  amount      Int
  type        String   // DEPOSIT, WITHDRAW, BUY_CHAPTER, AUTHOR_REVENUE, TRANSFER
  status      String   @default("SUCCESS") // PENDING, SUCCESS, FAILED (Cho cổng thanh toán)
  description String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  link      String?  
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- CÁC BẢNG TRUNG GIAN GIỮ NGUYÊN ---
model UnlockedChapter {
  id         String   @id @default(uuid())
  userId     String
  chapterId  String
  unlockedAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter    Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  comicId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comic     Comic    @relation(fields: [comicId], references: [id], onDelete: Cascade)

  @@unique([userId, comicId])
}

model Rating {
  id        String   @id @default(uuid())
  userId    String
  comicId   String
  score     Int
  review    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comic     Comic    @relation(fields: [comicId], references: [id], onDelete: Cascade)

  @@unique([userId, comicId])
}

model ReadingHistory {
  id        String   @id @default(uuid())
  userId    String
  comicId   String
  chapterId String
  updatedAt DateTime @default(now()) @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comic   Comic   @relation(fields: [comicId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, comicId])
}
