generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

enum Role {
  USER
  AUTHOR
  ADMIN
  ACCOUNTER
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String?
  name           String
  avatar         String?
  role           Role      @default(USER)
  points         Int       @default(0)
  totalDeposited Int       @default(0)
  createdAt      DateTime  @default(now())

  comics           Comic[]
  comments         Comment[]
  transactions     Transaction[]
  unlockedChapters UnlockedChapter[]
  favorites        Favorite[]
  readingHistories ReadingHistory[]
  notifications    Notification[]
  ratings          Rating[]
}

model Comic {
  id            String   @id @default(uuid())
  authorId      String
  title         String
  description   String
  coverUrl      String
  views         Int      @default(0)
  averageRating Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt // THÊM CỘT NÀY ĐỂ FIX LỖI DATABASE

  author           User              @relation(fields: [authorId], references: [id])
  chapters         Chapter[]
  tags             Tag[]
  comments         Comment[]
  favorites        Favorite[]
  ratings          Rating[]
  readingHistories ReadingHistory[]
}

model Chapter {
  id          String   @id @default(uuid())
  comicId     String
  title       String
  orderNumber Int
  price       Int      @default(0)
  createdAt   DateTime @default(now())

  comic            Comic             @relation(fields: [comicId], references: [id], onDelete: Cascade)
  images           Image[]           // ĐỔI TÊN ĐỂ KHỚP VỚI DATABASE
  unlockedBy       UnlockedChapter[]
  readingHistories ReadingHistory[]
  comments         Comment[]
}

model Image { // ĐÃ ĐỔI TÊN TỪ ChapterImage -> Image
  id         String  @id @default(uuid())
  chapterId  String
  url        String
  pageNumber Int

  chapter    Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(uuid())
  userId    String
  comicId   String?
  chapterId String?
  parentId  String?  // DÙNG CHO REPLY
  content   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comic     Comic?   @relation(fields: [comicId], references: [id], onDelete: Cascade)
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
}

// Các bảng còn lại (Tag, Transaction, Favorite, v.v.) giữ nguyên
model Tag {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  comics      Comic[]
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  amount      Int
  type        String
  description String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  comicId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comic     Comic    @relation(fields: [comicId], references: [id], onDelete: Cascade)
  @@unique([userId, comicId])
}

model Rating {
  id        String   @id @default(uuid())
  userId    String
  comicId   String
  score     Int
  review    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comic     Comic    @relation(fields: [comicId], references: [id], onDelete: Cascade)
  @@unique([userId, comicId])
}

model ReadingHistory {
  id        String   @id @default(uuid())
  userId    String
  comicId   String
  chapterId String
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comic     Comic    @relation(fields: [comicId], references: [id], onDelete: Cascade)
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  @@unique([userId, comicId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UnlockedChapter {
  id         String   @id @default(uuid())
  userId     String
  chapterId  String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter    Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  @@unique([userId, chapterId])
}